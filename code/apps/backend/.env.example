DATABASE_URL="postgresql://finance:finance@localhost:5432/finance"
PORT=3001

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose one: "anthropic" (direct) or "openrouter" (all models via one key)
AI_PROVIDER=anthropic

# API key for the selected provider
# - anthropic:   console.anthropic.com  →  sk-ant-...
# - openrouter:  openrouter.ai/keys     →  sk-or-...
AI_API_KEY=your-api-key-here

# Model identifier — format depends on provider:
# - anthropic:   claude-haiku-4-5-20251001 | claude-sonnet-4-6
# - openrouter:  anthropic/claude-haiku-4-5 | openai/gpt-4o | google/gemini-flash-1.5
AI_MODEL=claude-haiku-4-5-20251001
